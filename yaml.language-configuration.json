{
  "comments": {
    "lineComment": "#"
  },
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ]
  ],
  "autoCloseBefore": ": \n\t",
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*#?region\\b",
      "end": "^\\s*#\\s*#?endregion\\b"
    }
  },
  "onEnterRules": [
    {
      "beforeText": "(?<!\\\\|\\w:)#\\s*\\S",
      "afterText": "^(?!\\s*$).+",
      "action": {
        "indent": "none",
        "appendText": "# "
      }
    }
  ]
}
