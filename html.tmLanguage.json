{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "html",
  "scopeName": "text.html.basic",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#raw-script-inline"
    },
    {
      "include": "#raw-script"
    },
    {
      "include": "#raw-style-inline"
    },
    {
      "include": "#raw-style"
    },
    {
      "include": "#raw-textarea-inline"
    },
    {
      "include": "#raw-textarea"
    },
    {
      "include": "#raw-title-inline"
    },
    {
      "include": "#raw-title"
    },
    {
      "include": "#tag"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.html",
      "begin": "<!--",
      "end": "-->",
      "captures": {
        "0": {
          "name": "punctuation.definition.comment.html"
        }
      }
    },
    "raw-script-inline": {
      "name": "meta.script.html",
      "match": "(<)(script)\\b([^>]*)(>)(.*?)(</)(script)\\s*(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        },
        "5": {
          "name": "source.js",
          "patterns": [
            {
              "include": "source.js"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "7": {
          "name": "entity.name.tag.html"
        },
        "8": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    },
    "raw-script": {
      "name": "meta.script.html",
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "while": "^(?!\\s*</script[\\s>])",
      "contentName": "source.js",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "raw-style-inline": {
      "name": "meta.style.html",
      "match": "(<)(style)\\b([^>]*)(>)(.*?)(</)(style)\\s*(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        },
        "5": {
          "name": "source.css",
          "patterns": [
            {
              "include": "source.css"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "7": {
          "name": "entity.name.tag.html"
        },
        "8": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    },
    "raw-style": {
      "name": "meta.style.html",
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "while": "^(?!\\s*</style[\\s>])",
      "contentName": "source.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "raw-textarea-inline": {
      "name": "meta.textarea.html",
      "match": "(<)(textarea)\\b([^>]*)(>)(.*?)(</)(textarea)\\s*(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        },
        "5": {
          "name": "source.embedded",
          "patterns": [
            {
              "include": "source.embedded"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "7": {
          "name": "entity.name.tag.html"
        },
        "8": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    },
    "raw-textarea": {
      "name": "meta.textarea.html",
      "begin": "(<)(textarea)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "while": "^(?!\\s*</textarea[\\s>])",
      "contentName": "source.embedded",
      "patterns": [
        {
          "include": "source.embedded"
        }
      ]
    },
    "raw-title-inline": {
      "name": "meta.title.html",
      "match": "(<)(title)\\b([^>]*)(>)(.*?)(</)(title)\\s*(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        },
        "5": {
          "name": "source.embedded",
          "patterns": [
            {
              "include": "source.embedded"
            }
          ]
        },
        "6": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "7": {
          "name": "entity.name.tag.html"
        },
        "8": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    },
    "raw-title": {
      "name": "meta.title.html",
      "begin": "(<)(title)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "patterns": [
            {
              "include": "#attribute"
            }
          ]
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "while": "^(?!\\s*</title[\\s>])",
      "contentName": "source.embedded",
      "patterns": [
        {
          "include": "source.embedded"
        }
      ]
    },
    "tag": {
      "name": "meta.tag.html",
      "begin": "(<)(/?)([a-zA-Z][\\w:.-]*)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "3": {
          "name": "entity.name.tag.html"
        }
      },
      "end": "(/?)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        },
        "2": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#attribute"
        }
      ]
    },
    "attribute": {
      "patterns": [
        {
          "match": "([a-zA-Z][\\w:.-]*)(?=\\s*=)",
          "name": "entity.other.attribute-name.html"
        },
        {
          "begin": "(=)\\s*",
          "beginCaptures": {
            "1": {
              "name": "punctuation.separator.key-value.html"
            }
          },
          "end": "(?=[\\s>])",
          "patterns": [
            {
              "begin": "\"",
              "end": "\"",
              "name": "string.quoted.double.html",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.string.begin.html"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.string.end.html"
                }
              }
            },
            {
              "begin": "'",
              "end": "'",
              "name": "string.quoted.single.html",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.definition.string.begin.html"
                }
              },
              "endCaptures": {
                "0": {
                  "name": "punctuation.definition.string.end.html"
                }
              }
            },
            {
              "match": "[^\\s\"'<>=`]+",
              "name": "string.unquoted.html"
            }
          ]
        },
        {
          "match": "([a-zA-Z][\\w:.-]*)",
          "name": "entity.other.attribute-name.html"
        }
      ]
    }
  }
}
