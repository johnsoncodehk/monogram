{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "html",
  "scopeName": "text.html.basic",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#raw-script"
    },
    {
      "include": "#raw-style"
    },
    {
      "include": "#raw-textarea"
    },
    {
      "include": "#raw-title"
    },
    {
      "include": "#tag"
    }
  ],
  "repository": {
    "comment": {
      "name": "comment.block.html",
      "begin": "<!--",
      "end": "-->",
      "captures": {
        "0": {
          "name": "punctuation.definition.comment.html"
        }
      }
    },
    "raw-script": {
      "name": "meta.script.html",
      "begin": "(<)(script)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(script)\\s*(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "source.js",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "raw-style": {
      "name": "meta.style.html",
      "begin": "(<)(style)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(style)\\s*(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "source.css",
      "patterns": [
        {
          "include": "source.css"
        }
      ]
    },
    "raw-textarea": {
      "name": "meta.textarea.html",
      "begin": "(<)(textarea)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(textarea)\\s*(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "source.embedded",
      "patterns": [
        {
          "include": "source.embedded"
        }
      ]
    },
    "raw-title": {
      "name": "meta.title.html",
      "begin": "(<)(title)\\b([^>]*)(>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "4": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "end": "(</)(title)\\s*(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "contentName": "source.embedded",
      "patterns": [
        {
          "include": "source.embedded"
        }
      ]
    },
    "tag": {
      "name": "meta.tag.html",
      "begin": "(<)(/?)([a-zA-Z][\\w:.-]*)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "3": {
          "name": "entity.name.tag.html"
        }
      },
      "end": "(/?)(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        },
        "2": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "patterns": [
        {
          "include": "#attribute"
        }
      ]
    },
    "attribute": {
      "patterns": [
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.html",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.html"
            }
          }
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.html",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.html"
            }
          }
        },
        {
          "match": "=",
          "name": "punctuation.separator.key-value.html"
        },
        {
          "match": "[a-zA-Z][\\w:.-]*",
          "name": "entity.other.attribute-name.html"
        },
        {
          "match": "[^\\s>/'\"=]+",
          "name": "string.unquoted.html"
        }
      ]
    }
  }
}
