{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "yaml",
  "scopeName": "source.yaml",
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#explicit-key"
    },
    {
      "include": "#dquotekey"
    },
    {
      "include": "#squotekey"
    },
    {
      "include": "#key"
    },
    {
      "include": "#dquote"
    },
    {
      "include": "#squote"
    },
    {
      "include": "#num"
    },
    {
      "include": "#directive"
    },
    {
      "include": "#tag"
    },
    {
      "include": "#boolnull"
    },
    {
      "include": "#blockscalar"
    },
    {
      "include": "#plain"
    },
    {
      "include": "#docstart"
    },
    {
      "include": "#docend"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#alias"
    },
    {
      "include": "#indent"
    },
    {
      "include": "#dedent"
    },
    {
      "include": "#newline"
    },
    {
      "include": "#anchor"
    }
  ],
  "repository": {
    "docstart": {
      "name": "punctuation.definition.directives-end.readwrite.yaml",
      "match": "---"
    },
    "docend": {
      "name": "punctuation.definition.document-end.yaml",
      "match": "\\.\\.\\."
    },
    "directive": {
      "name": "keyword.other.directive.yaml",
      "match": "%(?:[^\\n#]|#(?<=\\S#))*"
    },
    "comment": {
      "name": "comment.line.number-sign.yaml",
      "match": "#[^\\n]*"
    },
    "dquotekey": {
      "name": "entity.name.tag.yaml",
      "match": "\"(?:\\\\.|[^\"\\\\])*\"(?=[\\t ]*:)"
    },
    "squotekey": {
      "name": "entity.name.tag.yaml",
      "match": "'(?:''|[^'])*'(?=[\\t ]*:)"
    },
    "dquote": {
      "name": "string.quoted.double.yaml",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.yaml"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.yaml"
        }
      },
      "patterns": [
        {
          "match": "\\\\.",
          "name": "constant.character.escape.yaml"
        }
      ]
    },
    "squote": {
      "name": "string.quoted.single.yaml",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.yaml"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.yaml"
        }
      },
      "patterns": [
        {
          "match": "''",
          "name": "constant.character.escape.yaml"
        }
      ],
      "applyEndPatternLast": true
    },
    "anchor": {
      "name": "entity.name.type.anchor.yaml",
      "match": "&[^\\s\\[\\]{},]+"
    },
    "alias": {
      "name": "variable.other.alias.yaml",
      "match": "\\*[^\\s\\[\\]{},]+"
    },
    "tag": {
      "name": "storage.type.tag.yaml",
      "match": "!(?:<[^>]*>|[^\\s\\[\\]{},]*)"
    },
    "blockscalar": {
      "name": "string.unquoted.block.yaml",
      "match": "(?!)"
    },
    "key": {
      "name": "entity.name.tag.yaml",
      "match": "(?:[^\\s\\-?:,\\[\\]{}#&*!|>'\"%@\\`]|[-?:](?=[^\\s,\\[\\]{}]))(?:[^:#\\n,\\[\\]{}]|:(?=[^\\s,\\]}])|#(?<=\\S#))*(?=[\\t ]*:(?:[\\s,\\[\\]{}]|$))"
    },
    "num": {
      "name": "constant.numeric.yaml",
      "match": "(?:[+-]?\\.(?:inf|Inf|INF)|\\.(?:nan|NaN|NAN)|0x[0-9a-fA-F]+|0o[0-7]+|[+-]?(?:\\.[0-9]+|[0-9]+(?:\\.[0-9]*)?)(?:[eE][+-]?[0-9]+)?)(?=[\\t ]+#|[\\t ]*(?:[\\r\\n,\\[\\]{}]|:(?:[\\s,\\[\\]{}]|$))|$)"
    },
    "boolnull": {
      "name": "constant.language.yaml",
      "match": "(?:true|True|TRUE|false|False|FALSE|null|Null|NULL|~)(?=[\\t ]+#|[\\t ]*(?:[\\r\\n,\\[\\]{}]|:(?:[\\s,\\[\\]{}]|$))|$)"
    },
    "plain": {
      "name": "string.unquoted.yaml",
      "match": "(?:[^\\s\\-?:,\\[\\]{}#&*!|>'\"%@\\`]|[-?:](?=[^\\s,\\[\\]{}]))(?:[^:#\\n,\\[\\]{}]|:(?=[^\\s,\\]}])|#(?<=\\S#))*"
    },
    "indent": {
      "name": "variable.other.yaml",
      "match": "(?!)"
    },
    "dedent": {
      "name": "variable.other.yaml",
      "match": "(?!)"
    },
    "newline": {
      "name": "variable.other.yaml",
      "match": "(?!)"
    },
    "explicit-key": {
      "match": "(\\?)([\\t ]+)(?:(?:&[^\\s\\[\\]{},]+|!(?:<[^>]*>|[^\\s\\[\\]{},]*))[\\t ]+)*((?:[^\\s\\-?:,\\[\\]{}#&*!|>'\"%@\\`]|[-?:](?=[^\\s,\\[\\]{}]))(?:[^:#\\n,\\[\\]{}]|:(?=[^\\s,\\]}])|#(?<=\\S#))*)",
      "captures": {
        "1": {
          "name": "punctuation.definition.map.key.yaml"
        },
        "3": {
          "name": "entity.name.tag.yaml"
        }
      }
    },
    "type-inner": {
      "patterns": [
        {
          "include": "#simple-type"
        }
      ]
    },
    "punctuation": {
      "match": ":|\\?|-|\\{|,|\\}|\\[|\\]",
      "name": "punctuation.yaml"
    }
  }
}
