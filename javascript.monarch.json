{
  "defaultToken": "invalid",
  "tokenPostfix": ".javascript",
  "ignoreCase": false,
  "brackets": [
    {
      "open": "(",
      "close": ")",
      "token": "delimiter.parenthesis"
    },
    {
      "open": "{",
      "close": "}",
      "token": "delimiter.bracket"
    },
    {
      "open": "[",
      "close": "]",
      "token": "delimiter.square"
    }
  ],
  "tokenizer": {
    "comment_slashstarstar": [
      [
        "[^*]+",
        "comment"
      ],
      [
        "\\*/",
        {
          "token": "comment",
          "next": "@pop"
        }
      ],
      [
        ".",
        "comment"
      ]
    ],
    "comment_slashstar": [
      [
        "[^*]+",
        "comment"
      ],
      [
        "\\*/",
        {
          "token": "comment",
          "next": "@pop"
        }
      ],
      [
        ".",
        "comment"
      ]
    ],
    "string_dquote_body": [
      [
        "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\})",
        "string.escape"
      ],
      [
        "[^\"\\\\]+",
        "string"
      ],
      [
        "\\\\.",
        "string.escape"
      ]
    ],
    "string_dquote": [
      {
        "include": "@string_dquote_body"
      },
      [
        "\"",
        {
          "token": "string",
          "switchTo": "@value"
        }
      ]
    ],
    "string_dquoteN": [
      {
        "include": "@string_dquote_body"
      },
      [
        "\"",
        {
          "token": "string",
          "next": "@pop"
        }
      ]
    ],
    "string_squote_body": [
      [
        "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\})",
        "string.escape"
      ],
      [
        "[^'\\\\]+",
        "string"
      ],
      [
        "\\\\.",
        "string.escape"
      ]
    ],
    "string_squote": [
      {
        "include": "@string_squote_body"
      },
      [
        "'",
        {
          "token": "string",
          "switchTo": "@value"
        }
      ]
    ],
    "string_squoteN": [
      {
        "include": "@string_squote_body"
      },
      [
        "'",
        {
          "token": "string",
          "next": "@pop"
        }
      ]
    ],
    "template_body": [
      [
        "\\\\(?:[nrtbfv0'\"\\\\`$]|x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|u\\{[0-9A-Fa-f]+\\})",
        "string.escape"
      ],
      [
        "\\$\\{",
        {
          "token": "delimiter.bracket",
          "next": "@templateInterp"
        }
      ],
      [
        "[^`\\\\$]+",
        "string"
      ]
    ],
    "template": [
      {
        "include": "@template_body"
      },
      [
        "`",
        {
          "token": "string",
          "switchTo": "@value"
        }
      ],
      [
        ".",
        "string"
      ]
    ],
    "templateN": [
      {
        "include": "@template_body"
      },
      [
        "`",
        {
          "token": "string",
          "next": "@pop"
        }
      ],
      [
        ".",
        "string"
      ]
    ],
    "templateInterp": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "/\\*\\*(?!/)",
        {
          "token": "comment",
          "next": "@comment_slashstarstar"
        }
      ],
      [
        "///.*$",
        "comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "/\\*",
        {
          "token": "comment",
          "next": "@comment_slashstar"
        }
      ],
      [
        "\"",
        {
          "token": "string",
          "next": "@string_dquoteN"
        }
      ],
      [
        "'",
        {
          "token": "string",
          "next": "@string_squoteN"
        }
      ],
      [
        "`",
        {
          "token": "string",
          "next": "@templateN"
        }
      ],
      [
        "\\{",
        {
          "token": "delimiter.bracket",
          "next": "@bracketCounting"
        }
      ],
      [
        "\\}",
        {
          "token": "delimiter.bracket",
          "next": "@pop"
        }
      ],
      {
        "include": "@interpExprBody"
      }
    ],
    "bracketCounting": [
      [
        "[ \\t\\r\\n]+",
        "white"
      ],
      [
        "/\\*\\*(?!/)",
        {
          "token": "comment",
          "next": "@comment_slashstarstar"
        }
      ],
      [
        "///.*$",
        "comment"
      ],
      [
        "//.*$",
        "comment"
      ],
      [
        "/\\*",
        {
          "token": "comment",
          "next": "@comment_slashstar"
        }
      ],
      [
        "\"",
        {
          "token": "string",
          "next": "@string_dquoteN"
        }
      ],
      [
        "'",
        {
          "token": "string",
          "next": "@string_squoteN"
        }
      ],
      [
        "`",
        {
          "token": "string",
          "next": "@templateN"
        }
      ],
      [
        "\\{",
        {
          "token": "delimiter.bracket",
          "next": "@bracketCounting"
        }
      ],
      [
        "\\}",
        {
          "token": "delimiter.bracket",
          "next": "@pop"
        }
      ],
      {
        "include": "@interpExprBody"
