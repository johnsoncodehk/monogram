{
  "comments": {
    "blockComment": [
      "<!--",
      "-->"
    ]
  },
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\"",
      "notIn": [
        "string",
        "comment"
      ]
    },
    {
      "open": "'",
      "close": "'",
      "notIn": [
        "string",
        "comment"
      ]
    }
  ],
  "surroundingPairs": [
    [
      "\"",
      "\""
    ],
    [
      "'",
      "'"
    ],
    [
      "<",
      ">"
    ]
  ],
  "autoCloseBefore": "> \n\t",
  "wordPattern": "[a-zA-Z][\\w:.\\-]*"
}
