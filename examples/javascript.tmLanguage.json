  "repository": {
    "regex-literal": {
      "name": "string.regexp.javascript",
      "begin": "(?:(?<=[=|\\^&<>+\\-*%!~(,.\\[?:{;])|(?<=\\binstanceof)|(?<=\\bin)|(?<=\\bnew)|(?<=\\bextends)|(?<=\\byield)|(?<=\\bget)|(?<=\\bset)|(?<=\\basync)|(?<=\\belse)|(?<=\\bdo)|(?<=\\breturn)|(?<=\\bthrow)|(?<=\\btry)|(?<=\\bfinally)|(?<=\\bcatch)|(?<=\\bof)|(?<=\\bcase)|(?<=\\bexport)|(?<=\\bdefault)|(?<=\\bimport)|(?<=\\bstatic)|(?<=\\baccessor)|(?<=\\btypeof)|(?<=\\bvoid)|(?<=\\bdelete)|(?<=\\bawait)|(?<=^))\\s*(?:((?:\\/\\*\\*(?!\\/)[\\s\\S]*?\\*\\/|\\/\\*[\\s\\S]*?\\*\\/)\\s*))?(/)(?![*/])",
      "beginCaptures": {
        "1": {
          "name": "comment.block.javascript"
        },
        "2": {
          "name": "punctuation.definition.string.begin.regexp.javascript"
        }
      },
      "end": "(/)([gimsuydv]*)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.string.end.regexp.javascript"
        },
        "2": {
          "name": "keyword.other.regexp.javascript"
        }
      },
      "patterns": [
        {
          "begin": "\\[",
          "end": "\\]",
          "name": "constant.other.character-class.regexp.javascript"
        },
        {
          "match": "\\\\.",
          "name": "constant.character.escape.regexp.javascript"
        }
      ]
    },
    "shebang": {
      "name": "comment.line.shebang.javascript",
      "match": "^#![^\\n]*"
    },
    "jsdoc": {
      "name": "comment.block.documentation.javascript",
      "begin": "\\/\\*\\*(?!\\/)",
      "end": "\\*\\/",
      "contentName": "meta.embedded.block.jsdoc"
    },
    "tripleslash": {
      "name": "comment.line.triple-slash.javascript",
      "match": "\\/\\/\\/\\s*<[^\\n]*"
    },
    "linecomment": {
      "name": "comment.line.double-slash.javascript",
      "match": "\\/\\/[^\\n]*"
    },
    "blockcomment": {
      "name": "comment.block.javascript",
      "begin": "\\/\\*",
      "end": "\\*\\/"
    },
    "ident": {
      "name": "variable.other.javascript",
      "match": "(?:[a-zA-Z_$\\p{L}\\p{Nl}]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$\\p{L}\\p{Nl}\\p{Nd}\\p{Mn}\\p{Mc}\\p{Pc}]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*"
    },
    "hexnumber": {
      "name": "constant.numeric.hex.javascript",
      "match": "0[xX][0-9a-fA-F]+(_[0-9a-fA-F]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "octalnumber": {
      "name": "constant.numeric.octal.javascript",
      "match": "0[oO][0-7]+(_[0-7]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "binarynumber": {
      "name": "constant.numeric.binary.javascript",
      "match": "0[bB][01]+(_[01]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "bigint": {
      "name": "constant.numeric.bigint.javascript",
      "match": "[0-9]+(_[0-9]+)*n(?![0-9A-Za-z_$\\\\])"
    },
    "number": {
      "name": "constant.numeric.float.javascript",
      "match": "[0-9]+(_[0-9]+)*(?:\\.[0-9]*(_[0-9]+)*)?(?:[eE][+-]?[0-9]+(_[0-9]+)*)?(?![0-9A-Za-z_$\\\\])"
    },
    "string-double": {
      "name": "string.quoted.double.javascript",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.javascript"
        }
      },
      "end": "\"|$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.javascript"
        }
      },
      "patterns": [
        {
          "match": "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
          "name": "constant.character.escape.javascript"
        }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.javascript",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.javascript"
        }
      },
      "end": "'|$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.javascript"
        }
      },
      "patterns": [
        {
          "match": "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
          "name": "constant.character.escape.javascript"
        }
      ]
    },
    "template": {
      "name": "string.quoted.other.template.javascript",
      "begin": "`",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.template.begin.javascript"
        }
      },
      "end": "`",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.template.end.javascript"
        }
      },
      "patterns": [
        {
          "match": "\\\\(?:[nrtbfv0'\"\\\\`$]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
          "name": "constant.character.escape.javascript"
        },
        {
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.begin.javascript"
            }
          },
          "end": "\\}",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.template-expression.end.javascript"
            }
          },
          "name": "meta.embedded.expression.javascript",
