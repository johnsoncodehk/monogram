        {
          "include": "#nested-parens"
        },
        {
          "include": "$self"
        }
      ]
    },
    "declaration-param-name": {
      "match": "(?<=[,(])\\s*(\\.\\.\\.)?\\s*((?:[a-zA-Z_$\\p{L}\\p{Nl}]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$\\p{L}\\p{Nl}\\p{Nd}\\p{Mn}\\p{Mc}\\p{Pc}]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*)(?=\\s*[,)=])",
      "captures": {
        "1": {
          "name": "keyword.operator.spread.javascript"
        },
        "2": {
          "name": "variable.parameter.javascript"
        }
      }
    },
    "declaration-params": {
      "name": "meta.parameters.javascript",
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.parameters.begin.javascript"
        }
      },
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.parameters.end.javascript"
        }
      },
      "patterns": [
        {
          "include": "#declaration-param-name"
