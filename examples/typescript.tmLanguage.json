          "include": "#type-inner"
        }
      ]
    },
    "simple-type": {
      "match": "(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*",
      "name": "entity.name.type.typescript"
    },
    "comparison": {
      "match": "[<>]",
      "name": "keyword.operator.comparison.typescript"
    },
    "regex-literal": {
      "name": "string.regexp.typescript",
      "begin": "(?:(?<=[=|\\^&<>+\\-*%!~,\\[(?:{;.])|(?<=\\bis)|(?<=\\bkeyof)|(?<=\\btypeof)|(?<=\\breadonly)|(?<=\\bnew)|(?<=\\bextends)|(?<=\\bin)|(?<=\\bas)|(?<=\\binstanceof)|(?<=\\bclass)|(?<=\\bsatisfies)|(?<=\\belse)|(?<=\\bdo)|(?<=\\bthrow)|(?<=\\btry)|(?<=\\bfinally)|(?<=\\bcase)|(?<=\\btype)|(?<=\\bstatic)|(?<=\\bvoid)|(?<=\\bdelete)|(?<=\\bawait)|(?<=\\byield)|(?<=^))\\s*(/)(?![*/])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.string.begin.regexp.typescript"
        }
      },
      "end": "(/)([gimsuydv]*)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.string.end.regexp.typescript"
        },
        "2": {
          "name": "keyword.other.regexp.typescript"
        }
      },
      "patterns": [
        {
          "begin": "\\[",
          "end": "\\]",
          "name": "constant.other.character-class.regexp.typescript"
        },
        {
          "match": "\\\\.",
          "name": "constant.character.escape.regexp.typescript"
        }
      ]
    },
    "shebang": {
      "name": "comment.line.shebang.typescript",
      "match": "^#![^\\n]*"
    },
    "jsdoc": {
      "name": "comment.block.documentation.typescript",
      "begin": "\\/\\*\\*(?!\\/)",
      "end": "\\*\\/",
      "contentName": "meta.embedded.block.jsdoc"
    },
    "tripleslash": {
      "name": "comment.line.triple-slash.typescript",
      "match": "\\/\\/\\/\\s*<[^\\n]*"
    },
    "linecomment": {
      "name": "comment.line.double-slash.typescript",
      "match": "\\/\\/[^\\n]*"
    },
    "blockcomment": {
      "name": "comment.block.typescript",
      "begin": "\\/\\*",
      "end": "\\*\\/"
    },
    "ident": {
      "name": "variable.other.typescript",
      "match": "(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*"
    },
    "hexnumber": {
      "name": "constant.numeric.hex.typescript",
      "match": "0[xX][0-9a-fA-F]+(_[0-9a-fA-F]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "octalnumber": {
      "name": "constant.numeric.octal.typescript",
      "match": "0[oO][0-7]+(_[0-7]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "binarynumber": {
      "name": "constant.numeric.binary.typescript",
      "match": "0[bB][01]+(_[01]+)*(?![0-9A-Za-z_$\\\\])"
    },
    "bigint": {
      "name": "constant.numeric.bigint.typescript",
      "match": "[0-9]+(_[0-9]+)*n(?![0-9A-Za-z_$\\\\])"
    },
    "number": {
      "name": "constant.numeric.float.typescript",
      "match": "[0-9]+(_[0-9]+)*(?:\\.[0-9]*(_[0-9]+)*)?(?:[eE][+-]?[0-9]+(_[0-9]+)*)?(?![0-9A-Za-z_$\\\\])"
    },
    "string-double": {
      "name": "string.quoted.double.typescript",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.typescript"
        }
      },
      "end": "\"|$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.typescript"
        }
      },
      "patterns": [
        {
          "match": "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
          "name": "constant.character.escape.typescript"
        }
      ]
    },
    "string-single": {
      "name": "string.quoted.single.typescript",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.typescript"
        }
      },
      "end": "'|$",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.typescript"
        }
      },
      "patterns": [
        {
          "match": "\\\\(?:[nrtbfv0'\"\\\\]|x[0-9a-fA-F]{2}|u[0-9a-fA-F]{4}|u\\{[0-9a-fA-F]+\\})",
          "name": "constant.character.escape.typescript"
        }
