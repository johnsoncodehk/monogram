      "beginCaptures": {
        "1": {
          "name": "variable.object.property.typescript"
        },
        "2": {
          "name": "keyword.operator.optional.typescript"
        },
        "3": {
          "name": "keyword.operator.type.annotation.typescript"
        }
      },
      "end": "(?=[;},])",
      "patterns": [
        {
          "include": "#type-inner"
