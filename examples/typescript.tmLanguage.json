    "generic-call": {
      "name": "meta.generic.typescript",
      "begin": "(?<=[\\w$\\]\\)])(<)(?=\\s*(?<T>(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*(?:\\s*<\\s*\\g<T>(?:\\s*,\\s*\\g<T>)*\\s*>)?)\\s*(?:,\\s*\\g<T>)*\\s*>\\s*[\\(`])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.begin.typescript"
        }
      },
      "end": "(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.end.typescript"
        }
      },
      "patterns": [
        {
          "include": "#type-inner"
        }
      ]
    },
    "generic-call-eol": {
      "name": "meta.generic.typescript",
      "begin": "(?<=[\\w$\\]\\)])(<)(?=\\s*(?<T>(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*(?:\\s*<\\s*\\g<T>(?:\\s*,\\s*\\g<T>)*\\s*>)?)\\s*(?:,\\s*\\g<T>)*\\s*>\\s*$)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.begin.typescript"
        }
      },
      "end": "(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.end.typescript"
        }
      },
      "patterns": [
        {
          "include": "#type-inner"
        }
      ]
    },
    "generic-call-multiline": {
      "name": "meta.angle-brackets.typescript",
      "begin": "(?<=[\\w$\\]\\)])(<)(?!(?<B>[^<>]*(?:<\\g<B>>[^<>]*)*)>)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.bracket.angle.open.typescript"
        }
      },
      "end": "(>)(?=\\s*[\\(`])|(>)(?=\\s*$)|(>)|(?=[=\\^+*/%!~;])",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.end.typescript"
        },
        "2": {
          "name": "punctuation.definition.typeparameters.end.typescript"
        },
        "3": {
          "name": "keyword.operator.comparison.typescript"
        }
      },
      "patterns": [
        {
          "include": "#generic-type"
        },
        {
          "match": "(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*(?=\\s*[,>])",
          "name": "entity.name.type.typescript"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.typescript"
        },
        {
          "include": "#ident"
        },
        {
          "include": "#angle-bracket-continuation"
        }
      ]
    },
    "angle-bracket-continuation": {
      "begin": "(?=\\s*$)",
      "end": "(?=>)|(?=[=\\^+*/%!~;])",
      "patterns": [
        {
          "include": "#generic-type"
        },
        {
          "match": "(?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*(?=\\s*[,>]|\\s*$)",
          "name": "entity.name.type.typescript"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.typescript"
        },
        {
          "include": "#ident"
        }
      ]
    },
    "generic-type": {
      "name": "meta.type.generic.typescript",
      "begin": "((?:[a-zA-Z_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})(?:[a-zA-Z0-9_$]|\\\\u[0-9a-fA-F]{4}|\\\\u\\{[0-9a-fA-F]+\\})*)(<)",
      "beginCaptures": {
        "1": {
          "name": "entity.name.type.typescript"
        },
        "2": {
          "name": "punctuation.definition.typeparameters.begin.typescript"
        }
      },
      "end": "(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.end.typescript"
