      "match": "\\b(type)\\b",
      "name": "storage.type.type.typescript"
    },
    "scope-storage-type-enum": {
      "match": "\\b(enum)\\b",
      "name": "storage.type.enum.typescript"
    },
    "scope-storage-type-namespace": {
      "match": "\\b(namespace|module)\\b",
      "name": "storage.type.namespace.typescript"
    },
    "scope-support-variable": {
      "match": "\\b(module|console|window|document|process|require|exports|global|globalThis)\\b",
      "name": "support.variable.typescript"
    },
    "scope-support-class": {
      "match": "\\b(Promise|Array|Map|Set|WeakMap|WeakSet|Error|RegExp|Date|Object|Function|Symbol)\\b",
      "name": "support.class.typescript"
    },
    "scope-storage-type-function-arrow": {
      "match": "=>",
      "name": "storage.type.function.arrow.typescript"
    },
    "scope-punctuation-accessor": {
      "match": "\\.",
      "name": "punctuation.accessor.typescript"
    },
    "operator-overrides": {
      "match": "(>>>=|\\*\\*=|<<=|>>=|\\?\\?=|\\|\\|=|&&=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|=)|(===|!==|==|!=)|(>>>|<<|>>)|(\\?\\?|\\|\\||&&)|(\\+\\+|--)|(\\*\\*|-|\\+|\\*|/|%)|(\\||&|\\^)|(!|~)",
      "captures": {
        "1": {
          "name": "keyword.operator.assignment.typescript"
        },
        "2": {
          "name": "keyword.operator.comparison.typescript"
        },
        "3": {
          "name": "keyword.operator.bitwise.shift.typescript"
        },
        "4": {
          "name": "keyword.operator.logical.typescript"
        },
        "5": {
          "name": "keyword.operator.increment-decrement.typescript"
        },
        "6": {
          "name": "keyword.operator.arithmetic.typescript"
        },
        "7": {
          "name": "keyword.operator.bitwise.typescript"
        },
        "8": {
          "name": "keyword.operator.logical.prefix.typescript"
        }
      }
    },
    "operators": {
      "match": "\\.\\.\\.|<=|>=",
      "name": "keyword.operator.typescript"
    },
    "scope-punctuation-separator-comma": {
      "match": ",",
      "name": "punctuation.separator.comma.typescript"
    },
    "scope-punctuation-bracket-square": {
      "match": "\\[|\\]",
      "name": "punctuation.bracket.square.typescript"
    },
    "scope-punctuation-bracket-round": {
      "match": "\\(|\\)",
      "name": "punctuation.bracket.round.typescript"
    },
    "scope-punctuation-bracket-curly": {
      "match": "\\{|\\}",
      "name": "punctuation.bracket.curly.typescript"
    },
    "scope-punctuation-terminator-statement": {
      "match": ";",
      "name": "punctuation.terminator.statement.typescript"
    },
    "scope-punctuation-accessor-optional": {
      "match": "\\?\\.",
      "name": "punctuation.accessor.optional.typescript"
    },
    "punctuation": {
      "match": "\\?|:",
      "name": "punctuation.typescript"
    }
  }
}
